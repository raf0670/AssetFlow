<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.assetflow.RegisterController"
      style="-fx-background-color: white;" prefWidth="900" prefHeight="700">

    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <Label text="Register New Account" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Label fx:id="errorLabel" textFill="RED"/>

    <TextField fx:id="fullNameField" promptText="Full Name" style="-fx-pref-height: 35px;"/>
    <TextField fx:id="usernameField" promptText="Username" style="-fx-pref-height: 35px;"/>
    <PasswordField fx:id="passwordField" promptText="Password" style="-fx-pref-height: 35px;"/>
    <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" style="-fx-pref-height: 35px;"/>

    <Button text="Register" onAction="#handleRegisterAction"
            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-pref-width: 200px; -fx-pref-height: 40px; -fx-font-size: 14px; -fx-cursor: hand;"/>

    <Button text="Back to Login" onAction="#backToLogin"
            style="-fx-background-color: transparent; -fx-text-fill: #2980b9; -fx-cursor: hand; -fx-underline: true;"/>
</VBox>