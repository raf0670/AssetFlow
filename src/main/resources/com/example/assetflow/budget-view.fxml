<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15" styleClass="panel" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.example.assetflow.BudgetController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label styleClass="h2" text="Set Monthly Budget" />
    <HBox alignment="CENTER" spacing="10">
        <Label text="Amount:" />
        <TextField fx:id="budgetField" promptText="Ex: 1000.00" />
    </HBox>
    <Button onAction="#handleSave" styleClass="add-button" text="Save Budget" />
</VBox>
